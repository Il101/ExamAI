# ===================================
# ExamAI Pro - Production Environment
# ===================================
# NEVER COMMIT THIS FILE WITH REAL VALUES!
# Copy to .env.production and fill with actual credentials

# Application Settings
ENVIRONMENT=production
DEBUG=False
SECRET_KEY=<generate-with-openssl-rand-hex-32>
FRONTEND_URL=https://examai-pro.vercel.app

# Database (Supabase or Railway Postgres)
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@[HOST]:5432/postgres
# For Supabase:
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_KEY=<supabase-service-key>

# Redis (Railway or standalone)
REDIS_URL=redis://default:[PASSWORD]@[HOST]:6379
REDIS_PASSWORD=<strong-redis-password>
CELERY_BROKER_URL=redis://default:[PASSWORD]@[HOST]:6379/0
CELERY_RESULT_BACKEND=redis://default:[PASSWORD]@[HOST]:6379/0

# LLM Configuration
GEMINI_API_KEY=<google-gemini-api-key>
GEMINI_MODEL=gemini-2.0-flash-exp
LLM_PROVIDER=gemini

# Email (SendGrid or SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=<sendgrid-api-key>
SMTP_TLS=true
EMAIL_FROM=noreply@examai-pro.com

# Monitoring & Error Tracking
SENTRY_DSN=<sentry-dsn>
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Security
CORS_ORIGINS=https://examai-pro.vercel.app,https://examai-pro-staging.vercel.app
ALLOWED_HOSTS=api.examai-pro.com,*.railway.app

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Cost Protection
MAX_DAILY_SPEND_FREE=0.50
MAX_DAILY_SPEND_PRO=5.00
MAX_TOKENS_PER_REQUEST=100000

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_SPACED_REPETITION=true
ENABLE_PDF_UPLOAD=true
